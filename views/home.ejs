<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Blogify - Discover Amazing Stories</title>
</head>
<body>
    <%- include("./partials/nave") %>

    <header class="hero-section text-center py-5 bg-primary-soft">
        <div class="container">
            <h1 class="display-4 fw-bold">Welcome to Blogify</h1>
            <p class="lead">Discover stories and ideas from amazing writers.</p>
        </div>
    </header>

    <main class="container my-5">
        <!-- Search & Filter -->
        <form method="GET" class="row g-3 mb-5">
            <div class="col-md-6">
                <input type="text" name="search" value="<%= search || '' %>" 
                       class="form-control" placeholder="Search blogs...">
            </div>
            <div class="col-md-3">
                <select name="sort" class="form-select">
                    <option value="newest" <%= (sort === 'newest' || !sort) ? 'selected' : '' %>>Newest First</option>
                    <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
                    <option value="title" <%= sort === 'title' ? 'selected' : '' %>>Title A-Z</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">Apply</button>
            </div>
            <% if (search) { %>
                <div class="col-12">
                    <a href="/" class="btn btn-outline-secondary">Clear Search</a>
                </div>
            <% } %>
        </form>

        <% if (!blogs || blogs.length === 0) { %>
            <div class="text-center py-5">
                <h4 class="text-muted">No blogs found.</h4>
            </div>
        <% } else { %>
            <div class="row">
                <% blogs.forEach(blog => { %>
                    <div class="col-lg-6 mb-4">
                        <div class="card h-100 shadow-sm">
                            <% if (blog.coverImageURL) { %>
                                <img src="<%= blog.coverImageURL %>" class="card-img-top" style="height: 220px; object-fit: cover;">
                            <% } %>
                            <div class="card-body">
                                <h5><%= blog.title %></h5>
                                <p class="text-muted">
                                    <%= blog.body ? blog.body.substring(0, 150) + '...' : '' %>
                                </p>
                                <a href="/blogs/<%= blog._id %>" class="btn btn-primary btn-sm">Read More</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <%- include("./partials/scripts") %>
</body>
</html>
