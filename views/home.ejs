<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Blogify - Discover Amazing Stories</title>
</head>
<body>
    <%- include("./partials/nave") %>

    <header class="hero-section text-center py-5 bg-primary-soft">
        <div class="container">
            <h1 class="display-4 fw-bold">Welcome to Blogify</h1>
            <p class="lead">Discover stories and ideas from amazing writers.</p>
        </div>
    </header>

    <main class="container my-5">
        
        <!-- Query Parameter Filter -->
        <form method="GET" class="row g-3 mb-5">
            <div class="col-md-6">
                <input type="text" 
                       name="search" 
                       value="<%= search || '' %>" 
                       class="form-control" 
                       placeholder="Search blogs by title or content...">
            </div>
            <div class="col-md-3">
                <select name="sort" class="form-select">
                    <option value="newest" <%= (sort === 'newest' || !sort) ? 'selected' : '' %>>Newest First</option>
                    <option value="oldest" <%= sort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
                    <option value="title" <%= sort === 'title' ? 'selected' : '' %>>Title A-Z</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">Apply Filter</button>
            </div>
            <% if (search) { %>
                <div class="col-12">
                    <a href="/" class="btn btn-outline-secondary">Clear Search</a>
                </div>
            <% } %>
        </form>

        <!-- Search Info -->
        <% if (search) { %>
            <p class="mb-4 text-muted">
                Showing results for <strong>"<%= search %>"</strong> 
                (<%= totalBlogs || 0 %> blogs found)
            </p>
        <% } %>

        <% if (!blogs || blogs.length === 0) { %>
            <div class="text-center py-5">
                <h4 class="text-muted">No blogs found.</h4>
                <% if (search) { %>
                    <a href="/" class="btn btn-primary mt-3">Clear Search</a>
                <% } else { %>
                    <a href="/blogs/add-new" class="btn btn-primary mt-3">Write Your First Blog</a>
                <% } %>
            </div>
        <% } else { %>
            <div class="row">
                <% blogs.forEach(blog => { %>
                    <div class="col-lg-6 mb-4">
                        <div class="card blog-card h-100 shadow-sm">
                            <% if (blog.coverImageURL) { %>
                                <img src="<%= blog.coverImageURL %>" 
                                     class="card-img-top" 
                                     style="height: 220px; object-fit: cover;"
                                     alt="<%= blog.title %>"
                                     onerror="this.src='/images/default-blog.png';">
                            <% } %>
                            <div class="card-body d-flex flex-column">
                                <h5 class="card-title"><%= blog.title %></h5>
                                <p class="card-text text-muted flex-grow-1">
                                    <%= blog.body ? blog.body.substring(0, 150) + '...' : 'No content' %>
                                </p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <small class="text-muted">
                                        By <%= blog.createdBy ? blog.createdBy.fullName : 'Anonymous' %>
                                    </small>
                                    <a href="/blogs/<%= blog._id %>" class="btn btn-primary btn-sm">Read More</a>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <!-- Pagination -->
        <% if (totalPages && totalPages > 1) { %>
        <nav class="mt-5">
            <ul class="pagination justify-content-center">
                <% for(let i = 1; i <= totalPages; i++) { %>
                    <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                        <a class="page-link" 
                           href="?page=<%= i %>&search=<%= encodeURIComponent(search || '') %>&sort=<%= sort || 'newest' %>">
                            <%= i %>
                        </a>
                    </li>
                <% } %>
            </ul>
        </nav>
        <% } %>

    </main>

    <%- include("./partials/scripts") %>
</body>
</html>
