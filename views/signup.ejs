<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Blogify</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .signup-container {
            background: white;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            width: 100%;
            max-width: 400px;
        }

        h2 {
            text-align: center;
            color: #333;
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 5px;
            color: #555;
            font-weight: 500;
        }

        input {
            width: 100%;
            padding: 12px;
            border: 2px solid #ddd;
            border-radius: 5px;
            font-size: 14px;
            transition: border-color 0.3s;
        }

        input:focus {
            outline: none;
            border-color: #667eea;
        }

        button {
            width: 100%;
            padding: 12px;
            background: #667eea;
            color: white;
            border: none;
            border-radius: 5px;
            font-size: 16px;
            cursor: pointer;
            transition: background 0.3s;
        }

        button:hover {
            background: #5568d3;
        }

        /* Google Button */
        .google-btn {
            width: 100%;
            padding: 12px;
            background: white;
            color: #333;
            border: 2px solid #ddd;
            border-radius: 5px;
            font-size: 16px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 15px;
            transition: all 0.3s;
        }

        .google-btn:hover {
            background: #f8f9fa;
            border-color: #667eea;
        }

        .google-icon {
            width: 20px;
            height: 20px;
        }

        .divider {
            text-align: center;
            margin: 25px 0;
            color: #999;
            position: relative;
        }

        .divider::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            height: 1px;
            background: #ddd;
        }

        .divider span {
            background: white;
            padding: 0 15px;
        }

        /* OTP Modal Styles */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.5);
            z-index: 1000;
            justify-content: center;
            align-items: center;
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            width: 90%;
            max-width: 400px;
            text-align: center;
            position: relative;
        }

        .modal-icon { font-size: 48px; margin-bottom: 15px; }
        .modal h3 { color: #333; margin-bottom: 10px; }
        .modal p { color: #666; margin-bottom: 25px; }

        .otp-inputs {
            display: flex;
            gap: 10px;
            justify-content: center;
            margin-bottom: 25px;
        }

        .otp-inputs input {
            width: 50px;
            height: 50px;
            text-align: center;
            font-size: 20px;
            font-weight: bold;
            border: 2px solid #ddd;
            border-radius: 8px;
        }

        .btn-verify {
            width: 100%;
            padding: 12px;
            background: #667eea;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .btn-resend {
            background: none;
            border: none;
            color: #667eea;
            margin-top: 15px;
            cursor: pointer;
        }
    </style>
</head>
<body>

    <!-- Signup Form -->
    <div class="signup-container">
        <h2>Create Account</h2>
        
        <form id="signupForm" action="/user/signup" method="POST">
            <div class="form-group">
                <label for="fullName">Full Name</label>
                <input type="text" id="fullName" name="fullName" required placeholder="Enter your full name">
            </div>
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required placeholder="Enter your email">
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required placeholder="Create a password">
            </div>
            <div class="form-group">
                <label for="confirmPassword">Confirm Password</label>
                <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="Confirm your password">
            </div>
            <button type="submit">Sign Up</button>
        </form>

        <div class="divider"><span>OR</span></div>

        <!-- Google Signup Button -->
        <a href="/user/auth/google" class="google-btn">
            <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" 
                 alt="Google" class="google-icon">
            Continue with Google
        </a>
    </div>

    <!-- OTP Modal -->
    <div class="modal-overlay" id="otpModal">
        <div class="modal">
            <button class="btn-close" onclick="closeModal()" style="position:absolute;top:15px;right:20px;font-size:28px;background:none;border:none;cursor:pointer;">×</button>
            
            <div class="modal-icon">🔐</div>
            <h3>Enter OTP</h3>
            <p>We've sent a 6-digit verification code to <strong id="displayEmail"></strong></p>
            
            <div class="otp-inputs">
                <input type="text" maxlength="1" class="otp-digit" data-index="0">
                <input type="text" maxlength="1" class="otp-digit" data-index="1">
                <input type="text" maxlength="1" class="otp-digit" data-index="2">
                <input type="text" maxlength="1" class="otp-digit" data-index="3">
                <input type="text" maxlength="1" class="otp-digit" data-index="4">
                <input type="text" maxlength="1" class="otp-digit" data-index="5">
            </div>
            
            <div class="error-message" id="otpError" style="color:red; margin:10px 0;"></div>
            
            <button class="btn-verify" onclick="verifyOTP()">Verify OTP</button>
            <button class="btn-resend" id="resendBtn" onclick="resendOTP()">Resend Code</button>
            <div class="timer" id="timer"></div>
        </div>
    </div>

    <script>
        // ... (Keep all your existing JavaScript from previous version)
        // I'll keep it short here - paste your full JS logic

        const modal = document.getElementById('otpModal');
        const displayEmail = document.getElementById('displayEmail');
        const otpInputs = document.querySelectorAll('.otp-digit');
        let currentEmail = "";

        // Form Submit
        document.getElementById('signupForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const password = document.getElementById('password').value;
            const confirm = document.getElementById('confirmPassword').value;

            if (password !== confirm) {
                alert("Passwords do not match!");
                return;
            }

            // Submit form normally (backend will handle OTP and re-render)
            this.submit();
        });

        // Auto show modal if backend passed emailForVerification (for future)
        window.onload = function() {
            <% if (typeof emailForVerification !== 'undefined' && emailForVerification) { %>
                currentEmail = "<%= emailForVerification %>";
                displayEmail.textContent = currentEmail;
                modal.classList.add('active');
            <% } %>
        };

        // OTP Input Logic (same as before)
        otpInputs.forEach((input, index) => {
            input.addEventListener('input', () => {
                if (input.value.length === 1 && index < 5) {
                    otpInputs[index + 1].focus();
                }
            });
        });

        async function verifyOTP() {
            const otp = Array.from(otpInputs).map(i => i.value).join('');
            if (otp.length !== 6) {
                document.getElementById('otpError').textContent = "Please enter 6 digits";
                return;
            }

            const res = await fetch('/user/verify-otp', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ email: currentEmail, otp })
            });

            const data = await res.json();
            if (data.success) {
                alert("✅ Account created successfully!");
                window.location.href = "/";
            } else {
                alert(data.message || "Invalid OTP");
            }
        }

        function closeModal() {
            modal.classList.remove('active');
        }
    </script>
</body>
</html>
