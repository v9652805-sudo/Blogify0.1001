<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>My Bookmarks - Reading List | Blogify</title>
    <style>
        .bookmark-card {
            border-radius: 12px;
            transition: all 0.3s ease;
            background: white;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        }

        .bookmark-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.15);
        }

        .bookmark-img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-radius: 12px 12px 0 0;
        }

        .bookmark-content {
            padding: 1.5rem;
        }

        .bookmark-meta {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.85rem;
            color: #64748b;
        }

        .collection-badge {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            background: #f1f5f9;
            border-radius: 20px;
            font-size: 0.8rem;
            color: #475569;
            font-weight: 600;
        }

        .bookmark-actions {
            display: flex;
            gap: 0.5rem;
            margin-top: 1rem;
        }

        .bookmark-actions button {
            padding: 0.4rem 0.8rem;
            font-size: 0.85rem;
            border-radius: 6px;
        }

        .star-rating {
            font-size: 1.2rem;
            color: #fbbf24;
        }

        .reading-progress {
            margin-top: 1rem;
            padding: 0.75rem;
            background: #f8fafc;
            border-radius: 8px;
            font-size: 0.85rem;
        }

        .progress-bar-reading {
            height: 6px;
            background: #e2e8f0;
            border-radius: 3px;
            overflow: hidden;
            margin-top: 0.5rem;
        }

        .progress-bar-reading-fill {
            height: 100%;
            background: linear-gradient(90deg, #6366f1, #4f46e5);
            transition: width 0.3s ease;
        }

        .sidebar {
            position: sticky;
            top: 100px;
        }

        .sidebar-card {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            margin-bottom: 1.5rem;
        }

        .collection-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .collection-item {
            padding: 0.75rem;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 0.5rem;
        }

        .collection-item:hover {
            background: #f1f5f9;
        }

        .collection-item.active {
            background: #6366f1;
            color: white;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .stat-box {
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            color: white;
            padding: 1.5rem;
            border-radius: 12px;
            text-align: center;
        }

        .stat-number {
            font-size: 1.8rem;
            font-weight: 700;
        }

        .stat-label {
            font-size: 0.85rem;
            opacity: 0.9;
            margin-top: 0.5rem;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 1rem;
        }

        .empty-state-icon {
            font-size: 4rem;
            color: #cbd5e1;
            margin-bottom: 1rem;
        }

        @media (max-width: 768px) {
            .sidebar {
                position: static;
                top: auto;
            }

            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>
</head>
<body>
    <%- include("./partials/nave") %>

    <div class="container my-5">
        <div class="row">
            <!-- Main Content -->
            <div class="col-lg-9">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h2 class="fw-bold mb-0">
                        <i class="fas fa-bookmark text-primary"></i> My Reading List
                    </h2>
                </div>

                <!-- Filter & Sort Controls -->
                <div class="card mb-4 shadow-sm">
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <select id="collectionFilter" class="form-select">
                                    <option value="">All Collections</option>
                                    <option value="default">Default</option>
                                    <option value="to-read">To Read</option>
                                    <option value="favorites">Favorites</option>
                                    <option value="research">Research</option>
                                    <option value="inspiration">Inspiration</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <select id="readFilter" class="form-select">
                                    <option value="">All Items</option>
                                    <option value="unread">Unread</option>
                                    <option value="read">Read</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Bookmarks Grid -->
                <div id="bookmarksContainer" class="row g-4">
                    <div class="col-12 text-center py-5">
                        <p class="text-muted">Loading your bookmarks...</p>
                    </div>
                </div>

                <!-- Pagination -->
                <nav id="paginationContainer" class="mt-4"></nav>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-3">
                <!-- Reading Stats -->
                <div class="sidebar-card">
                    <h5 class="fw-bold mb-3">
                        <i class="fas fa-chart-pie text-primary"></i> Reading Stats
                    </h5>
                    <div class="stats-grid">
                        <div class="stat-box">
                            <div class="stat-number" id="totalBookmarks">0</div>
                            <div class="stat-label">Total</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-number" id="readCount">0</div>
                            <div class="stat-label">Read</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-number" id="unreadCount">0</div>
                            <div class="stat-label">Unread</div>
                        </div>
                        <div class="stat-box">
                            <div class="stat-number" id="readPercentage">0%</div>
                            <div class="stat-label">Progress</div>
                        </div>
                    </div>
                    <div class="progress">
                        <div id="readProgressBar" class="progress-bar" role="progressbar" style="width: 0%"></div>
                    </div>
                </div>

                <!-- Collections -->
                <div class="sidebar-card">
                    <h5 class="fw-bold mb-3">
                        <i class="fas fa-folder text-primary"></i> Collections
                    </h5>
                    <ul class="collection-list" id="collectionsContainer">
                        <li class="collection-item active" onclick="filterByCollection('')">
                            <i class="fas fa-book"></i> All Bookmarks
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <%- include("./partials/scripts") %>

    <script>
        let currentPage = 1;
        let currentCollection = '';
        let currentReadFilter = '';

        // Load bookmarks on page load
        document.addEventListener('DOMContentLoaded', () => {
            loadBookmarks();
            loadReadingStats();
            loadCollections();
        });

        // Filter listeners
        document.getElementById('collectionFilter').addEventListener('change', (e) => {
            currentCollection = e.target.value;
            currentPage = 1;
            loadBookmarks();
        });

        document.getElementById('readFilter').addEventListener('change', (e) => {
            currentReadFilter = e.target.value;
            currentPage = 1;
            loadBookmarks();
        });

        async function loadBookmarks() {
            try {
                let url = `/bookmarks?page=${currentPage}`;
                if (currentCollection) url += `&collection=${currentCollection}`;
                if (currentReadFilter) url += `&isRead=${currentReadFilter === 'read'}`;

                const res = await axios.get(url);
                const { bookmarks, total, pages } = res.data;

                renderBookmarks(bookmarks);
                renderPagination(pages, total);
            } catch (error) {
                notify.error('Failed to load bookmarks');
                document.getElementById('bookmarksContainer').innerHTML = `
                    <div class="col-12 empty-state">
                        <div class="empty-state-icon">📚</div>
                        <h5>No bookmarks yet</h5>
                        <p class="text-muted">Start bookmarking blogs to build your reading list</p>
                    </div>
                `;
            }
        }

        function renderBookmarks(bookmarks) {
            if (bookmarks.length === 0) {
                document.getElementById('bookmarksContainer').innerHTML = `
                    <div class="col-12 empty-state">
                        <div class="empty-state-icon">📚</div>
                        <h5>No bookmarks found</h5>
                        <p class="text-muted">Try adjusting your filters</p>
                    </div>
                `;
                return;
            }

            const html = bookmarks.map(bookmark => `
                <div class="col-md-6 col-lg-12">
                    <div class="bookmark-card">
                        <% if (bookmark.blog.coverImageURL) { %>
                            <img src="${bookmark.blog.coverImageURL}" class="bookmark-img" alt="${bookmark.blog.title}">
                        <% } else { %>
                            <div class="bookmark-img bg-light d-flex align-items-center justify-content-center">
                                <i class="fas fa-image text-muted fa-2x"></i>
                            </div>
                        <% } %>
                        
                        <div class="bookmark-content">
                            <div class="d-flex align-items-start justify-content-between mb-2">
                                <h6 class="fw-bold mb-0">${bookmark.blog.title}</h6>
                                <button class="btn btn-sm btn-outline-danger" onclick="deleteBookmark('${bookmark._id}')" title="Remove bookmark">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>

                            <div class="bookmark-meta mb-2">
                                <span><i class="fas fa-user"></i> ${bookmark.blog.createdBy.fullName}</span>
                                <span><i class="fas fa-clock"></i> ${bookmark.formattedDate}</span>
                                <span class="collection-badge">${bookmark.collection}</span>
                            </div>

                            ${bookmark.notes ? `<p class="text-muted small mb-2">${bookmark.notes}</p>` : ''}

                            <div class="star-rating">
                                ${'⭐'.repeat(Math.round(bookmark.rating))}
                                <small class="text-muted">(${bookmark.rating}/5)</small>
                            </div>

                            <div class="reading-progress">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="read${bookmark._id}" 
                                           ${bookmark.readingProgress.isRead ? 'checked' : ''} 
                                           onchange="toggleReadStatus('${bookmark._id}', this.checked)">
                                    <label class="form-check-label" for="read${bookmark._id}">
                                        Mark as read
                                    </label>
                                </div>
                            </div>

                            <div class="bookmark-actions">
                                <a href="/blogs/${bookmark.blog._id}" class="btn btn-primary btn-sm">
                                    <i class="fas fa-book-open"></i> Read
                                </a>
                                <button class="btn btn-outline-primary btn-sm" onclick="editBookmark('${bookmark._id}')">
                                    <i class="fas fa-edit"></i> Edit
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');

            document.getElementById('bookmarksContainer').innerHTML = html;
        }

        function renderPagination(pages, total) {
            if (pages <= 1) {
                document.getElementById('paginationContainer').innerHTML = '';
                return;
            }

            let html = '<nav><ul class="pagination justify-content-center">';
            
            if (currentPage > 1) {
                html += `<li class="page-item"><a class="page-link" onclick="goToPage(${currentPage - 1})">Previous</a></li>`;
            }

            for (let i = 1; i <= pages; i++) {
                if (i === currentPage) {
                    html += `<li class="page-item active"><span class="page-link">${i}</span></li>`;
                } else {
                    html += `<li class="page-item"><a class="page-link" onclick="goToPage(${i})">${i}</a></li>`;
                }
            }

            if (currentPage < pages) {
                html += `<li class="page-item"><a class="page-link" onclick="goToPage(${currentPage + 1})">Next</a></li>`;
            }

            html += '</ul></nav>';
            document.getElementById('paginationContainer').innerHTML = html;
        }

        async function loadReadingStats() {
            try {
                const res = await axios.get('/bookmarks/stats');
                const { total, read, unread, readingPercentage } = res.data.stats;

                document.getElementById('totalBookmarks').textContent = total;
                document.getElementById('readCount').textContent = read;
                document.getElementById('unreadCount').textContent = unread;
                document.getElementById('readPercentage').textContent = readingPercentage + '%';
                document.getElementById('readProgressBar').style.width = readingPercentage + '%';
            } catch (error) {
                console.error('Failed to load reading stats:', error);
            }
        }

        async function loadCollections() {
            try {
                const res = await axios.get('/bookmarks/collections');
                const collections = res.data.collections;

                const html = collections.map(col => `
                    <li class="collection-item" onclick="filterByCollection('${col.name}')">
                        <i class="fas fa-folder"></i> ${col.name} 
                        <span class="badge bg-primary float-end">${col.count}</span>
                    </li>
                `).join('');

                document.getElementById('collectionsContainer').innerHTML = `
                    <li class="collection-item active" onclick="filterByCollection('')">
                        <i class="fas fa-book"></i> All Bookmarks
                    </li>
                    ${html}
                `;
            } catch (error) {
                console.error('Failed to load collections:', error);
            }
        }

        function filterByCollection(collection) {
            currentCollection = collection;
            currentPage = 1;
            document.getElementById('collectionFilter').value = collection;
            loadBookmarks();
        }

        function goToPage(page) {
            currentPage = page;
            loadBookmarks();
            window.scrollTo(0, 0);
        }

        async function toggleReadStatus(bookmarkId, isRead) {
            try {
                await axios.put(`/bookmarks/${bookmarkId}`, { isRead });
                notify.success('Reading status updated');
                loadReadingStats();
            } catch (error) {
                notify.error('Failed to update reading status');
            }
        }

        async function deleteBookmark(bookmarkId) {
            if (!confirm('Remove this bookmark?')) return;
            
            try {
                await axios.delete(`/bookmarks/${bookmarkId}`);
                notify.success('Bookmark removed');
                loadBookmarks();
                loadReadingStats();
            } catch (error) {
                notify.error('Failed to remove bookmark');
            }
        }

        function editBookmark(bookmarkId) {
            // Open modal for editing bookmark
            notify.info('Edit feature coming soon');
        }
    </script>
</body>
</html>
