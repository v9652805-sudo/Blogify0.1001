<!-- Navigation Bar -->
<nav class="navbar navbar-expand-lg sticky-top" style="background: rgba(255,255,255,0.95); backdrop-filter: blur(12px); box-shadow: 0 2px 15px rgba(0,0,0,0.1);">
    <div class="container-fluid">
        <!-- Brand -->
        <a class="navbar-brand fw-bold fs-3 text-primary" href="/">
            <i class="fas fa-feather"></i> Blogify
        </a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNavDropdown">
            <!-- Left Links -->
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link fw-medium" href="/"><i class="fas fa-home"></i> Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link fw-medium" href="/blogs"><i class="fas fa-compass"></i> Explore</a>
                </li>
                
                <% if (locals.user) { %>
                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="/blogs/add-new">
                            <i class="fas fa-plus"></i> Write
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-medium" href="/bookmarks">
                            <i class="fas fa-bookmark"></i> Bookmarks
                        </a>
                    </li>
                <% } %>
            </ul>

            <!-- Right Side -->
            <ul class="navbar-nav ms-auto align-items-center gap-2">
                <!-- Search -->
                <li class="nav-item">
                    <form class="d-flex" method="GET" action="/">
                        <input class="form-control form-control-sm me-2" type="search" 
                               name="search" placeholder="Search blogs..." 
                               value="<%= search || '' %>">
                    </form>
                </li>

                <% if (locals.user) { %>
                    <!-- Notifications -->
                    <li class="nav-item">
                        <button class="btn btn-link position-relative" id="notificationBell">
                            <i class="fas fa-bell fa-lg" style="color: #6366f1;"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="notificationBadge" style="display: none;">
                                <span id="notificationCount">0</span>
                            </span>
                        </button>
                    </li>

                    <!-- Dark Mode -->
                    <li class="nav-item">
                        <button class="btn btn-link" id="themeToggle">
                            <i class="fas fa-moon fa-lg" style="color: #6366f1;"></i>
                        </button>
                    </li>

                    <!-- User Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" role="button" data-bs-toggle="dropdown">
                            <img src="<%= locals.user.profileImageURL || '/imgs/default.png' %>" 
                                 alt="<%= locals.user.fullName %>" width="36" height="36" 
                                 class="rounded-circle border border-2 border-light"
                                 onerror="this.src='/imgs/default.png';">
                            <span class="fw-medium d-none d-md-inline"><%= locals.user.fullName.split(" ")[0] %></span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li class="dropdown-header">
                                <div class="d-flex align-items-center gap-2">
                                    <img src="<%= locals.user.profileImageURL || '/imgs/default.png' %>" width="32" height="32" class="rounded-circle">
                                    <div>
                                        <p class="mb-0 fw-bold"><%= locals.user.fullName %></p>
                                        <small class="text-muted"><%= locals.user.email %></small>
                                    </div>
                                </div>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            
                            <li><a class="dropdown-item" href="/user/profile"><i class="fas fa-user"></i> My Profile</a></li>
                            <li><a class="dropdown-item" href="/badges"><i class="fas fa-medal"></i> Badges</a></li>
                            <li><a class="dropdown-item" href="/bookmarks"><i class="fas fa-bookmark"></i> Bookmarks</a></li>
                            <li><a class="dropdown-item" href="/share"><i class="fas fa-share-alt"></i> Share Analytics</a></li>
                            
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="/user/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                        </ul>
                    </li>
                <% } else { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/user/signup">Sign Up</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-primary rounded-pill px-4" href="/user/signin">Sign In</a>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>
