<!-- Blog View Sidebar - Add this to views/view.ejs after the like button section -->

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h6 class="card-title fw-bold mb-3">💾 Save & Share</h6>
        
        <!-- Bookmark Button -->
        <button class="btn btn-outline-primary w-100 mb-2" id="bookmarkBtn" onclick="toggleBookmark()">
            <i class="fas fa-bookmark"></i> Add to Reading List
        </button>

        <!-- Share Buttons -->
        <div class="btn-group w-100 mb-2" role="group">
            <button class="btn btn-outline-info btn-sm flex-fill" id="shareTwitter" onclick="shareOn('twitter')">
                <i class="fab fa-twitter"></i> Twitter
            </button>
            <button class="btn btn-outline-info btn-sm flex-fill" id="shareFacebook" onclick="shareOn('facebook')">
                <i class="fab fa-facebook"></i> Facebook
            </button>
            <button class="btn btn-outline-info btn-sm flex-fill" id="shareLinkedin" onclick="shareOn('linkedin')">
                <i class="fab fa-linkedin"></i> LinkedIn
            </button>
        </div>

        <button class="btn btn-outline-secondary w-100" id="shareMore" onclick="showShareModal()">
            <i class="fas fa-share-alt"></i> Share More
        </button>
    </div>
</div>

<!-- Share Analytics Card (for blog author only) -->
<div id="shareStatsCard" class="card shadow-sm" style="display: none;">
    <div class="card-body">
        <h6 class="card-title fw-bold mb-3">📊 Share Stats</h6>
        <div class="d-grid gap-2">
            <small>
                <i class="fas fa-share-alt text-primary"></i> 
                <span id="totalShares">0</span> Shares
            </small>
            <small>
                <i class="fas fa-mouse text-success"></i> 
                <span id="totalClicks">0</span> Clicks
            </small>
            <small>
                <i class="fas fa-eye text-info"></i> 
                <span id="totalViews">0</span> Views from Shares
            </small>
        </div>
    </div>
</div>

<!-- Share Modal -->
<div class="modal fade" id="shareModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Share Blog</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-primary" onclick="shareOn('twitter')">
                        <i class="fab fa-twitter"></i> Share on Twitter
                    </button>
                    <button class="btn btn-outline-primary" onclick="shareOn('facebook')">
                        <i class="fab fa-facebook"></i> Share on Facebook
                    </button>
                    <button class="btn btn-outline-primary" onclick="shareOn('linkedin')">
                        <i class="fab fa-linkedin"></i> Share on LinkedIn
                    </button>
                    <button class="btn btn-outline-primary" onclick="shareOn('whatsapp')">
                        <i class="fab fa-whatsapp"></i> Share on WhatsApp
                    </button>
                    <button class="btn btn-outline-primary" onclick="shareOn('email')">
                        <i class="fas fa-envelope"></i> Share via Email
                    </button>
                    <button class="btn btn-outline-primary" onclick="copyLink()">
                        <i class="fas fa-link"></i> Copy Link
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
const blogId = '<%= blog._id %>';
const blogTitle = '<%= blog.title %>';
const blogUrl = window.location.href;
const isAuthor = <%= locals.user && locals.user._id.toString() === blog.createdBy._id.toString() ? 'true' : 'false' %>;

// ====================== BOOKMARK FUNCTIONS ======================
async function toggleBookmark() {
    try {
        const isBookmarked = await checkIfBookmarked();
        
        if (isBookmarked) {
            // Remove bookmark
            const bookmark = await getBookmarkId();
            await axios.delete(`/bookmarks/${bookmark}`);
            document.getElementById('bookmarkBtn').classList.remove('btn-primary');
            document.getElementById('bookmarkBtn').classList.add('btn-outline-primary');
            document.getElementById('bookmarkBtn').innerHTML = '<i class="fas fa-bookmark"></i> Add to Reading List';
            notify.success('Removed from reading list');
        } else {
            // Add bookmark
            await axios.post(`/bookmarks/blog/${blogId}`, { collection: 'default' });
            document.getElementById('bookmarkBtn').classList.remove('btn-outline-primary');
            document.getElementById('bookmarkBtn').classList.add('btn-primary');
            document.getElementById('bookmarkBtn').innerHTML = '<i class="fas fa-bookmark"></i> Saved to Reading List';
            notify.success('Added to reading list');
        }
    } catch (error) {
        notify.error('Failed to update bookmark');
    }
}

async function checkIfBookmarked() {
    try {
        const res = await axios.get(`/bookmarks/check/${blogId}`);
        return res.data.isBookmarked;
    } catch (error) {
        return false;
    }
}

async function getBookmarkId() {
    try {
        const res = await axios.get('/bookmarks?page=1');
        const bookmark = res.data.bookmarks.find(b => b.blog._id === blogId);
        return bookmark?._id;
    } catch (error) {
        return null;
    }
}

// Initialize bookmark button
document.addEventListener('DOMContentLoaded', async () => {
    if (!<%= locals.user ? 'true' : 'false' %>) return;
    
    const isBookmarked = await checkIfBookmarked();
    if (isBookmarked) {
        document.getElementById('bookmarkBtn').classList.remove('btn-outline-primary');
        document.getElementById('bookmarkBtn').classList.add('btn-primary');
        document.getElementById('bookmarkBtn').innerHTML = '<i class="fas fa-bookmark"></i> Saved to Reading List';
    }

    // Load share stats if author
    if (isAuthor) {
        loadShareStats();
    }
});

// ====================== SHARE FUNCTIONS ======================
async function shareOn(platform) {
    try {
        const result = await axios.post('/share/create', {
            blogId,
            platform
        });

        const trackingUrl = result.data.share.shareUrl;
        let url = '';

        switch(platform) {
            case 'twitter':
                url = `https://twitter.com/intent/tweet?url=${encodeURIComponent(trackingUrl)}&text=${encodeURIComponent(blogTitle)}`;
                break;
            case 'facebook':
                url = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(trackingUrl)}`;
                break;
            case 'linkedin':
                url = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(trackingUrl)}`;
                break;
            case 'whatsapp':
                url = `https://wa.me/?text=${encodeURIComponent(blogTitle + ' ' + trackingUrl)}`;
                break;
            case 'email':
                url = `mailto:?subject=${encodeURIComponent(blogTitle)}&body=${encodeURIComponent(trackingUrl)}`;
                break;
        }

        if (url) {
            window.open(url, '_blank', 'width=600,height=400');
            notify.success('Opening share dialog...');
        }

        // Close modal if open
        const modal = bootstrap.Modal.getInstance(document.getElementById('shareModal'));
        if (modal) modal.hide();
    } catch (error) {
        notify.error('Failed to create share link');
    }
}

function showShareModal() {
    const modal = new bootstrap.Modal(document.getElementById('shareModal'));
    modal.show();
}

function copyLink() {
    navigator.clipboard.writeText(blogUrl);
    notify.success('Link copied to clipboard!');
}

// ====================== SHARE STATS ======================
async function loadShareStats() {
    try {
        const res = await axios.get(`/share/blog/${blogId}/stats`);
        const { stats } = res.data;

        if (stats.totalShares > 0) {
            document.getElementById('shareStatsCard').style.display = 'block';
            document.getElementById('totalShares').textContent = stats.totalShares;
            document.getElementById('totalClicks').textContent = stats.totalClicks;
            document.getElementById('totalViews').textContent = stats.conversions.views;
        }
    } catch (error) {
        console.error('Failed to load share stats:', error);
    }
}
</script>

