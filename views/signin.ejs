<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head") %>
    <title>Sign In - Blogify</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            height: 100%;
        }

        body {
            background: linear-gradient(135deg, #6366f1 0%, #4f46e5 50%, #764ba2 100%);
            min-height: 100dvh;
            font-family: 'Inter', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            padding: 0.75rem;
        }

        .auth-container {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            flex: 1;
            padding: 0.5rem 0;
        }

        .auth-card {
            background: rgba(255, 255, 255, 0.97);
            backdrop-filter: blur(12px);
            border-radius: 16px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
            overflow: hidden;
            width: 100%;
            max-width: 420px;
            animation: slideIn 0.4s ease-out;
        }

        .auth-card-body {
            padding: 2rem 1.75rem;
        }

        .auth-header {
            text-align: center;
            margin-bottom: 1.5rem;
        }

        .auth-header h2 {
            font-size: 1.6rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 0.4rem;
            letter-spacing: -0.5px;
        }

        .auth-header p {
            color: #64748b;
            font-size: 0.9rem;
            font-weight: 500;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-label {
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 0.4rem;
            display: block;
            font-size: 0.9rem;
        }

        .form-control {
            width: 100%;
            border-radius: 10px;
            padding: 0.75rem 0.9rem;
            border: 2px solid #e2e8f0;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }

        .form-control:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
            outline: none;
        }

        .form-control::placeholder {
            color: #94a3b8;
        }

        .input-group {
            display: flex;
            align-items: stretch;
        }

        .input-group .form-control {
            border-radius: 10px 0 0 10px;
            margin: 0;
        }

        .input-group .btn {
            border-radius: 0 10px 10px 0;
            border: 2px solid #e2e8f0;
            border-left: none;
            background: white;
            color: #64748b;
            font-size: 1.1rem;
            padding: 0.75rem 0.9rem;
            min-width: 44px;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .input-group .btn:hover {
            background: #f8fafc;
            color: #334155;
        }

        .btn-signin {
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            border: none;
            border-radius: 10px;
            padding: 0.8rem 1.5rem;
            color: white;
            font-weight: 700;
            font-size: 0.95rem;
            width: 100%;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 0.75rem;
            font-family: 'Inter', sans-serif;
        }

        .btn-signin:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(99, 102, 241, 0.3);
        }

        .btn-signin:active {
            transform: translateY(0);
        }

        .btn-signin:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            transform: none;
        }

        .forgot-link {
            text-align: center;
            margin-bottom: 1rem;
        }

        .forgot-link a {
            color: #6366f1;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.85rem;
            transition: color 0.3s ease;
        }

        .forgot-link a:hover {
            color: #4f46e5;
        }

        .divider {
            display: flex;
            align-items: center;
            margin: 1rem 0;
            color: #94a3b8;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e2e8f0;
        }

        .divider span {
            padding: 0 0.75rem;
            font-size: 0.8rem;
            font-weight: 600;
        }

        .btn-google {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            width: 100%;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            padding: 0.8rem 1.5rem;
            background: white;
            color: #1e293b;
            font-weight: 600;
            font-size: 0.9rem;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
            margin-bottom: 1rem;
        }

        .btn-google:hover {
            border-color: #cbd5e1;
            background: #f8fafc;
            transform: translateY(-1px);
        }

        .signup-link {
            text-align: center;
            margin-top: 1rem;
            color: #64748b;
            font-size: 0.85rem;
        }

        .signup-link a {
            color: #6366f1;
            text-decoration: none;
            font-weight: 700;
            transition: color 0.3s ease;
        }

        .signup-link a:hover {
            color: #4f46e5;
        }

        .alert {
            border-radius: 10px;
            padding: 0.85rem;
            margin-bottom: 1rem;
            border: none;
            font-weight: 500;
            font-size: 0.9rem;
        }

        .alert-danger {
            background-color: #fee2e2;
            color: #991b1b;
        }

        /* Animations */
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Loading State */
        .spinner-border {
            display: inline-block;
            width: 1rem;
            height: 1rem;
            vertical-align: text-bottom;
            border: 2px solid currentColor;
            border-right-color: transparent;
            border-radius: 50%;
            animation: spinner-border 0.75s linear infinite;
        }

        @keyframes spinner-border {
            to {
                transform: rotate(360deg);
            }
        }

        /* Responsive */
        @media (max-width: 576px) {
            body {
                padding: 0.5rem;
                justify-content: flex-start;
                padding-top: 0.75rem;
                padding-bottom: 0.75rem;
            }

            .auth-container {
                align-items: flex-start;
                padding: 0;
            }

            .auth-card {
                max-width: 100%;
                border-radius: 14px;
            }

            .auth-card-body {
                padding: 1.5rem 1.25rem;
            }

            .auth-header h2 {
                font-size: 1.4rem;
            }

            .auth-header p {
                font-size: 0.85rem;
            }

            .form-control {
                padding: 0.7rem 0.85rem;
                font-size: 16px; /* Prevents iOS zoom on focus */
            }

            .form-label {
                font-size: 0.85rem;
            }

            .btn-signin {
                padding: 0.75rem 1.5rem;
            }

            .btn-google {
                padding: 0.75rem 1.5rem;
            }
        }

        @media (max-width: 360px) {
            .auth-card-body {
                padding: 1.25rem 1rem;
            }

            .auth-header h2 {
                font-size: 1.25rem;
            }

            .auth-header {
                margin-bottom: 1.25rem;
            }
        }
    </style>
<base target="_blank">
</head>
<body>
    <%- include("./partials/nave") %>

    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-card-body">
                <div class="auth-header">
                    <h2>Welcome Back</h2>
                    <p>Sign in to access your Blogify account</p>
                </div>

                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>

                <form id="signinForm">
                    <div class="form-group">
                        <label class="form-label">Email Address</label>
                        <input type="email" id="email" name="email" class="form-control" placeholder="you@example.com" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <div class="input-group">
                            <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required>
                            <button type="button" class="btn" id="togglePassword" title="Toggle password visibility">
                                👁️
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="btn-signin" id="submitBtn">
                        Sign In
                    </button>
                </form>

                <div class="forgot-link">
                    <a href="#" id="forgotLink">Forgot Password?</a>
                </div>

                <div class="divider">
                    <span>OR</span>
                </div>

                <a href="/user/auth/google" class="btn-google">
                    <img src="https://upload.wikimedia.org/wikipedia/commons/c/c1/Google_%22G%22_logo.svg" 
                         width="20" height="20" alt="Google">
                    Continue with Google
                </a>

                <p class="signup-link">
                    Don't have an account? 
                    <a href="/user/signup">Create one</a>
                </p>
            </div>
        </div>
    </div>

    <%- include("./partials/scripts") %>

    <script>
        // Password Visibility Toggle
        const toggleBtn = document.getElementById('togglePassword');
        toggleBtn.addEventListener('click', function () {
            const passwordField = document.getElementById('password');
            if (passwordField.type === 'password') {
                passwordField.type = 'text';
                this.textContent = '🙈';
            } else {
                passwordField.type = 'password';
                this.textContent = '👁️';
            }
        });

        // Sign In Form
        document.getElementById('signinForm').addEventListener('submit', async function (e) {
            e.preventDefault();
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="spinner-border me-2"></span>Signing In...`;

            const data = {
                email: document.getElementById('email').value.trim(),
                password: document.getElementById('password').value
            };

            try {
                const res = await fetch('/user/signin', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await res.json();

                if (result.success) {
                    window.location.href = "/";
                } else {
                    alert(result.message || "Invalid email or password");
                    submitBtn.disabled = false;
                    submitBtn.textContent = "Sign In";
                }
            } catch (err) {
                alert("Something went wrong. Please try again.");
                submitBtn.disabled = false;
                submitBtn.textContent = "Sign In";
            }
        });

        // Forgot Password
        document.getElementById('forgotLink').addEventListener('click', async function (e) {
            e.preventDefault();
            const email = prompt("Enter your registered email address:");
            if (!email) return;

            try {
                const res = await fetch('/user/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email })
                });
                const data = await res.json();
                alert(data.message);
            } catch (err) {
                alert("Failed to send reset link");
            }
        });
    </script>
</body>
</html>
